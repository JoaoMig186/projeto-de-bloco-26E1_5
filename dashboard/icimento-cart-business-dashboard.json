{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "id": 1,
      "title": "Total de Carrinhos Criados",
      "type": "stat",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "icimento_cart_service_total_carts_total"
        }
      ]
    },
    {
      "id": 2,
      "title": "Total de Carrinhos Finalizados",
      "type": "stat",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "icimento_cart_service_total_carts_completed_total"
        }
      ]
    },
    {
      "id": 3,
      "title": "Carrinhos Abandonados (> 15min)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "(icimento_cart_service_total_carts_total offset 15m) - (icimento_cart_service_total_carts_completed_total offset 15m)"
        }
      ]
    },
    {
      "id": 4,
      "title": "Taxa de Conversão (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 5 },
      "targets": [
        {
          "expr": "100 * (icimento_cart_service_total_carts_completed_total / icimento_cart_service_total_carts_total)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Taxa de Novos Carrinhos (últimos 5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 5 },
      "targets": [
        {
          "expr": "rate(icimento_cart_service_total_carts_total[5m])",
          "legendFormat": "Criados por seg"
        }
      ]
    },
    {
      "id": 6,
      "title": "Taxa de Finalização (últimos 5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 5 },
      "targets": [
        {
          "expr": "rate(icimento_cart_service_total_carts_completed_total[5m])",
          "legendFormat": "Finalizados por seg"
        }
      ]
    }
  ],
  "refresh": "5s",
