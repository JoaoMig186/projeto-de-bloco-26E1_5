{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "id": 1,
      "title": "Total de Produtos Criados",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(product_creation_total)"
        }
      ]
    },
    {
      "id": 2,
      "title": "Total de Sincronizações Kafka",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "sum(kafka_product_sync_time_ms_count)"
        }
      ]
    },
    {
      "id": 3,
      "title": "Tempo Máximo Sincronização (ms)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "max(kafka_product_sync_time_ms_max)"
        }
      ]
    },
    {
      "id": 4,
      "title": "Produtos Criados por Categoria",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(product_creation_total) by (category)",
          "legendFormat": "{{category}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Taxa de Criação de Produtos",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(product_creation_total[5m])) by (category)",
          "legendFormat": "{{category}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Tempo Médio de Sincronização Kafka (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "rate(kafka_product_sync_time_ms_sum[5m]) / rate(kafka_product_sync_time_ms_count[5m])",
          "legendFormat": "Tempo Médio"
        }
      ]
    },
    {
      "id": 7,
      "title": "Taxa de Mensagens Kafka (Eventos/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "rate(kafka_product_sync_time_ms_count[5m])",
          "legendFormat": "Mensagens / s"
        }
      ]
    }
  ],
